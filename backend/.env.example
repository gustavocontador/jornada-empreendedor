# Database
DATABASE_URL=postgresql://user:password@localhost:5432/jornada_empreendedor
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application
APP_NAME="Jornada do Empreendedor de Sucesso"
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8000

# Email (opcional - para recuperação de senha)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# File Storage
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
MAX_UPLOAD_SIZE=10485760

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production
